  object FQryFinanceiro: TFDQuery
    Active = True
    Connection = FConexaoFinanceiro
    SQL.Strings = (
      'select cr.id_conta_receber, cr.id_origem, cr.id_cliente,'
      '       cr.nome_cliente, cr.data_emissao, cr.data_vencimento,'
      '       cr.valor as valor_financeiro, cr.status,'
      '       case cr.status'
      '         when '#39'ABERTA'#39' then '#39'Aberta'#39
      '         when '#39'RECEBIDA'#39' then '#39'Fechada'#39
      '         when '#39'CANCELADA'#39' then '#39'Cancelada'#39
      '         else cr.status'
      '       end as status_descricao'
